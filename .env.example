# ===========================================
# EU AI Act Compliance Tool - Environment Variables
# Copy this file to .env.local and fill in your values
# WARNING: Never commit .env.local to Git!
# ===========================================

# Database (Neon PostgreSQL)
# DATABASE_URL: Pooled connection string (for runtime queries)
#   Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true
# DIRECT_DATABASE_URL: Direct connection string (for migrations only)
#   Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# Get both from: Neon Console → Dashboard → Connection Details
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/eu_ai_act?sslmode=require&pgbouncer=true"
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/eu_ai_act?sslmode=require"

# NextAuth.js
# NEXTAUTH_URL: Your canonical app URL (production domain)
NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET: Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-to-a-secure-random-string-min-32-chars"

# Payment Gateway Configuration
PAYMENT_GATEWAY=

# Creem (active gateway)
CREEM_API_KEY=
CREEM_STORE_ID=
CREEM_WEBHOOK_SECRET=

# Creem Product IDs (configure in Creem dashboard)
CREEM_STARTER_PRODUCT_ID=
CREEM_PROFESSIONAL_PRODUCT_ID=
CREEM_BUSINESS_PRODUCT_ID=
CREEM_ENTERPRISE_PRODUCT_ID=

# Paddle (reserved - fill in after registration)
PADDLE_VENDOR_ID=
PADDLE_API_KEY=
PADDLE_SANDBOX_VENDOR_ID=
PADDLE_SANDBOX_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_STARTER_PLAN_ID=
PADDLE_PROFESSIONAL_PLAN_ID=
PADDLE_BUSINESS_PLAN_ID=
PADDLE_ENTERPRISE_PLAN_ID=

# OAuth Providers (Google) - Optional
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth Providers (GitHub) - Optional
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# SMTP Email (nodemailer) - Optional (password reset disabled without)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""
SMTP_REPLY_TO=""

# Multi-language (next-intl)
NEXT_PUBLIC_DEFAULT_LOCALE="en"
