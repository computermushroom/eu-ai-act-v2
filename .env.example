# ===========================================
# EU AI Act Compliance Tool - Environment Variables
# Copy this file to .env.local and fill in your values
# WARNING: Never commit .env.local to Git!
# ===========================================

# ───────────────────────────────────────────
# Database (Neon PostgreSQL) — REQUIRED
# ───────────────────────────────────────────
# DATABASE_URL: Pooled connection string (for runtime queries)
#   Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true
#   Get from: Neon Console → Dashboard → Connection Details → Pooled connection
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/eu_ai_act?sslmode=require&pgbouncer=true"
# DIRECT_DATABASE_URL: Direct connection string (for Prisma migrations only)
#   Get from: Neon Console → Dashboard → Connection Details → Direct connection
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/eu_ai_act?sslmode=require"

# ───────────────────────────────────────────
# NextAuth.js — REQUIRED
# ───────────────────────────────────────────
# NEXTAUTH_URL: Your canonical app URL (production domain)
NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET: Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-to-a-secure-random-string-min-32-chars"

# ───────────────────────────────────────────
# Payment Gateway — REQUIRED (both gateways need credentials)
# ───────────────────────────────────────────
# Active gateway is controlled via GlobalConfig table (runtime, no restart).
# Default: Paddle (primary). Admin can switch to Creem via /admin/payment-gateway.
# Both gateways must have credentials configured for webhook processing.

# Paddle (PRIMARY gateway — default for all new checkouts)
#   Get API Key from: Paddle Dashboard → Developer Tools → Authentication
#   Get Webhook Secret from: Paddle Dashboard → Developer Tools → Notifications
PADDLE_API_KEY=""
PADDLE_WEBHOOK_SECRET=""
# Paddle Price IDs (one per pricing tier)
PADDLE_STARTER_PRICE_ID=""
PADDLE_PROFESSIONAL_PRICE_ID=""
PADDLE_BUSINESS_PRICE_ID=""
PADDLE_ENTERPRISE_PRICE_ID=""

# Creem (BACKUP gateway — activated by admin via /admin/payment-gateway)
#   Get API Key & Webhook Secret from: Creem Dashboard → Settings → API Keys
#   Get Product IDs from: Creem Dashboard → Products → Create Product
CREEM_API_KEY=""
CREEM_WEBHOOK_SECRET=""
# Creem Product IDs (one per pricing tier)
CREEM_STARTER_PRODUCT_ID=""
CREEM_PROFESSIONAL_PRODUCT_ID=""
CREEM_BUSINESS_PRODUCT_ID=""
CREEM_ENTERPRISE_PRODUCT_ID=""

# ───────────────────────────────────────────
# Admin Access — Optional (required for /admin pages)
# ───────────────────────────────────────────
# ADMIN_EMAILS: Comma-separated list of admin email addresses
#   Only these emails can access /admin/payment-gateway
ADMIN_EMAILS=""

# ───────────────────────────────────────────
# AI / LLM — Optional (required for AI Assistant feature)
# ───────────────────────────────────────────
# LLM_PROVIDER: Which LLM provider to use
#   Values: "openai" (default) | "anthropic"
LLM_PROVIDER="openai"

# OpenAI
#   Get API Key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# OPENAI_MODEL: Model to use (default: gpt-4o-mini)
OPENAI_MODEL="gpt-4o-mini"

# Anthropic (alternative to OpenAI)
#   Get API Key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
# ANTHROPIC_MODEL: Model to use (default: claude-sonnet-4-20250514)
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# ───────────────────────────────────────────
# OAuth Providers — Optional
# ───────────────────────────────────────────
# Google OAuth
#   Get from: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth
#   Get from: GitHub Settings → Developer settings → OAuth Apps
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ───────────────────────────────────────────
# Email (SMTP) — Optional (required for email notifications)
# ───────────────────────────────────────────
# Option A: Resend (recommended, easiest setup)
#   Get API Key from: https://resend.com/api-keys
RESEND_API_KEY=""

# Option B: Custom SMTP
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""
SMTP_REPLY_TO=""

# SMTP Provider Preset (auto-configures host/port/secure)
#   Values: "gmail" | "outlook" | "office365" | "yahoo" | "zoho" | "sendgrid" | "mailgun"
SMTP_PROVIDER=""

# ───────────────────────────────────────────
# API Documentation — Optional
# ───────────────────────────────────────────
# NEXTAUTH_URL is used as the server URL in the OpenAPI spec
#   Swagger UI is available at: /docs
#   OpenAPI JSON is available at: /api/docs

# ───────────────────────────────────────────
# Internationalization — Optional
# ───────────────────────────────────────────
# NEXT_PUBLIC_DEFAULT_LOCALE: Default language
#   Values: "en" (default) | "de" | "fr" | "es" | "nl" | "it" | "pl" | "sv"
NEXT_PUBLIC_DEFAULT_LOCALE="en"

# ───────────────────────────────────────────
# Sentry Error Monitoring — Optional
# ───────────────────────────────────────────
# Get DSN from: Sentry Dashboard → Settings → Projects → Client Keys (DSN)
# SENTRY_ORG and SENTRY_PROJECT are used for sourcemap uploads during build
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Sentry: Set to "true" to suppress build warnings (default: false in production)
SENTRY_SILENT=""
